# Example environment variables for server
# Copy to .env and fill with real values before running

# MongoDB connection string (use mongodb://localhost:27017/wondertravel for local)
MONGO_URI=

# Gemini API key for the generative AI (optional)
GEMINI_API_KEY=

# JWT secret for auth tokens
JWT_SECRET=change_this_secret

# Comma-separated frontend origins allowed to call the API.
# Leave blank for local development, set in production.
CORS_ORIGIN=http://localhost:5173,http://localhost

# Server port
PORT=5000
